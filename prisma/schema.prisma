generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String?
  googleId      String?        @unique
  role          UserRole       @default(CUSTOMER)
  createdAt     DateTime       @default(now())
  deletedAt     DateTime?
  updatedAt     DateTime?      @updatedAt
  phone         String         @unique @default("") @db.VarChar(8)
  status        UserStatus     @default(ACTIVE)
  addresses     Address[]
  cart          Cart?
  orders        Order[]
  reviews       Review[]
  wishlist      Wishlist[]
  sessions      Session[]
  fcms          FCM[]
  devices       Device[]
  notifications Notification[]
  reports       Report[]
  activityLogs  ActivityLog[]
}

model Category {
  id        Int           @id @default(autoincrement())
  name      String
  createdAt DateTime      @default(now())
  deletedAt DateTime?
  parentId  Int?
  slug      String        @unique
  updatedAt DateTime?     @updatedAt
  state     CategoryState
  image     String?
  featured  Boolean       @default(false)
  parent    Category?     @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[]    @relation("SubCategories")
  products  Product[]
}

model Product {
  id            Int                @id @default(autoincrement())
  name          String
  description   String?
  price         Decimal            @db.Decimal(12, 2)
  stock         Int
  categoryId    Int
  createdAt     DateTime           @default(now())
  deletedAt     DateTime?
  discountPrice Decimal?           @db.Decimal(12, 2)
  isPublished   Boolean            @default(false)
  sku           String?            @unique
  barcode       String?            @db.VarChar(64)
  slug          String             @unique
  updatedAt     DateTime?          @updatedAt
  featured      Boolean            @default(false)
  hasVariants   Boolean            @default(false)
  state         ProductState       @default(ACTIVE)
  cartItems     CartItem[]
  orderItems    OrderItem[]
  category      Category           @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  reviews       Review[]
  wishedBy      Wishlist[]
  features      ProductFeature[]
  colors        ProductColor[]
  productSizes  ProductSize[]
  productStocks ProductStock[]
  attributes    ProductAttribute[]
  variants      ProductVariant[]
}

// ─── Generic attribute / variant систем ─────────────────────────────────────
// Бараа нь олон төрлийн шинж чанартай (ӨНГӨ/ХЭМЖЭЭ/МАТЕРИАЛ/ЗАГВАР), төрөл бүр
// олон утгатай. ProductVariant нь эдгээр утгуудын ХОСЛОЛ (N-хэмжээст) + нөөц/үнэ.

enum AttributeType {
  COLOR
  SIZE
  MATERIAL
  DESIGN
}

model ProductAttribute {
  id        Int                     @id @default(autoincrement())
  productId Int
  type      AttributeType
  product   Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductAttributeValue[]

  @@unique([productId, type]) // нэг барааны нэг төрөл нэг л удаа
}

model ProductAttributeValue {
  id           Int                   @id @default(autoincrement())
  attributeId  Int
  value        String // "Улаан", "XL", "Хөвөн", "Slim" г.м
  hex          String? // COLOR төрөлд
  imageUrl     String? // COLOR төрөлд (хуучин — нэг зураг upload)
  attribute    ProductAttribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variantLinks ProductVariantValue[]
  imageLinks   ProductImageLink[]

  @@index([attributeId])
}

model ProductVariant {
  id            String                @id @default(cuid())
  productId     Int
  price         Decimal?              @db.Decimal(12, 2)
  discountPrice Decimal?              @db.Decimal(12, 2)
  stock         Int                   @default(0)
  sku           String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime?             @updatedAt
  deletedAt     DateTime?
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  values        ProductVariantValue[]
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@index([productId])
}

model ProductVariantValue {
  id               Int                   @id @default(autoincrement())
  variantId        String
  attributeValueId Int
  variant          ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue   ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeValueId])
  @@index([attributeValueId])
}

model ProductImage {
  id        Int                @id @default(autoincrement())
  url       String
  productId Int
  createdAt DateTime           @default(now())
  deletedAt DateTime?
  updatedAt DateTime?          @updatedAt
  product   Product            @relation(fields: [productId], references: [id])
  links     ProductImageLink[]
}

// Зураг ↔ хувилбарын утга (өнгө/загвар/материал) M2M холбоос.
// Нэг зургийг олон утгатай, нэг утгыг олон зурагтай холбоно.
model ProductImageLink {
  id               Int                   @id @default(autoincrement())
  imageId          Int
  attributeValueId Int
  image            ProductImage          @relation(fields: [imageId], references: [id], onDelete: Cascade)
  attributeValue   ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([imageId, attributeValueId])
  @@index([attributeValueId])
}

model ProductFeature {
  id          Int     @id @default(autoincrement())
  productId   Int
  title       String
  description String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model ProductColor {
  id        Int            @id @default(autoincrement())
  productId Int
  hex       String
  name      String
  imageUrl  String?
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stocks    ProductStock[]
}

model ProductSize {
  id        Int            @id @default(autoincrement())
  productId Int
  sizeName  String
  value     String
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stocks    ProductStock[]
}

model ProductStock {
  id             String        @id @default(cuid())
  productId      Int
  productColorId Int?
  productSizeId  Int?
  price          Decimal?      @db.Decimal(12, 2)
  discountPrice  Decimal?      @db.Decimal(12, 2)
  stock          Int           @default(0)
  sku            String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime?     @updatedAt
  deletedAt      DateTime?
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  color          ProductColor? @relation(fields: [productColorId], references: [id], onDelete: SetNull)
  size           ProductSize?  @relation(fields: [productSizeId], references: [id], onDelete: SetNull)
  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@unique([productId, productColorId, productSizeId])
  @@index([productId])
}

model Cart {
  id         Int        @id @default(autoincrement())
  userId     Int        @unique
  user       User       @relation(fields: [userId], references: [id])
  items      CartItem[]
  totalCount Int        @default(0)
  totalPrice Decimal    @default(0) @db.Decimal(12, 2)
  deletedAt  DateTime?
  updatedAt  DateTime?  @updatedAt
}

model CartItem {
  id               Int             @id @default(autoincrement())
  cartId           Int
  productId        Int
  productStockId   String?
  productVariantId String?
  quantity         Int
  deletedAt        DateTime?
  updatedAt        DateTime?       @updatedAt
  createdAt        DateTime        @default(now())
  cart             Cart            @relation(fields: [cartId], references: [id])
  product          Product         @relation(fields: [productId], references: [id])
  productStock     ProductStock?   @relation(fields: [productStockId], references: [id])
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
}

model Order {
  id          Int         @id @default(autoincrement())
  orderNumber String      @unique
  userId      Int
  status      OrderStatus @default(PENDING)
  totalPrice  Decimal     @default(0) @db.Decimal(12, 2)
  totalCount  Int         @default(0)
  createdAt   DateTime    @default(now())
  addressId   Int?
  branchId    Int?
  deletedAt   DateTime?
  updatedAt   DateTime?   @updatedAt
  note        String?
  address     Address?    @relation(fields: [addressId], references: [id])
  branch      Branch?     @relation(fields: [branchId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
  paymentId   Int?
  payment     Payment?
}

model OrderItem {
  id               Int             @id @default(autoincrement())
  orderId          Int
  productId        Int
  productStockId   String?
  productVariantId String?
  price            Decimal         @db.Decimal(12, 2)
  quantity         Int
  deletedAt        DateTime?
  updatedAt        DateTime?       @updatedAt
  order            Order           @relation(fields: [orderId], references: [id])
  product          Product         @relation(fields: [productId], references: [id])
  productStock     ProductStock?   @relation(fields: [productStockId], references: [id])
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
}

model Payment {
  id        Int         @id @default(autoincrement())
  orderId   Int         @unique
  method    String
  amount    Decimal     @db.Decimal(12, 2)
  status    String      @default("PENDING")
  deletedAt DateTime?
  updatedAt DateTime?   @updatedAt
  type      PaymentType @default(QPAY)
  order     Order       @relation(fields: [orderId], references: [id])
}

model Review {
  id        Int       @id @default(autoincrement())
  rating    Int
  comment   String?
  userId    Int
  productId Int
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  updatedAt DateTime? @updatedAt
  product   Product   @relation(fields: [productId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model Address {
  id         Int       @id @default(autoincrement())
  city       String
  khoroo     String
  detail     String
  phone      String
  latitude   Decimal?
  longitude  Decimal?
  userId     Int?
  isMain     Boolean   @default(false)
  deletedAt  DateTime?
  districtId Int
  user       User?     @relation(fields: [userId], references: [id])
  orders     Order[]
  district   District  @relation(fields: [districtId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  lastActivity DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Otp {
  id        Int      @id @default(autoincrement())
  email     String?
  phone     String?
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  type      OtpType

  @@unique([email, type])
  @@unique([phone, type])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Device {
  id          Int       @id @default(autoincrement())
  userId      Int
  platform    String?
  deviceName  String?
  ipAddresses String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  lastSeenAt  DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fcms        FCM[]
}

model FCM {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  userId    Int
  deviceId  Int?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  device    Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
}

model District {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  createdAt   DateTime  @default(now())
  deliverable Boolean   @default(true)
  addresses   Address[]
}

// Дэлгүүрийн салбар / байршил
model Branch {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  city      String    @default("Улаанбаатар")
  district  String?
  khoroo    String?
  address   String? // дэлгэрэнгүй хаяг
  latitude  Decimal?  @db.Decimal(10, 7)
  longitude Decimal?  @db.Decimal(10, 7)
  isActive  Boolean   @default(true)
  hours     Json? // ажлын цагийн хуваарь: [{ open, from, to }] x7 (Да..Ня)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  orders    Order[]
}

model StoreSettings {
  id                   Int           @id @default(autoincrement())
  storeName            String        @default("Дэлгүүр")
  logo                 String        @default("")
  banners              String[]      @default([])
  storeDesc            String        @default("")
  phone                String        @default("")
  email                String        @default("")
  address              String        @default("")
  fee                  Decimal       @default(0) @db.Decimal(12, 2)
  feeThreshold         Decimal       @default(0) @db.Decimal(12, 2)
  maxOrderValue        Decimal       @default(0) @db.Decimal(12, 2) // 0 = хязгааргүй
  monthlyRevenueGoal   Decimal       @default(0) @db.Decimal(12, 2) // сарын орлогын зорилт (0 = тохируулаагүй)
  lowStockThreshold    Int           @default(5) // үлдэгдэл энэ тооноос бага бол "бага үлдэгдэл" гэж тооцно
  onlyInStock          Boolean       @default(false)
  onlyPublished        Boolean       @default(true)
  showStock            Boolean       @default(true) // үлдэгдлийн тоог хэрэглэгчид харуулах эсэх
  showStatProducts     Boolean       @default(true)
  showStatOrders       Boolean       @default(true)
  showStatSatisfaction Boolean       @default(true)
  showStatDelivery     Boolean       @default(true)
  payQpay              Boolean       @default(true)
  payBankApp           Boolean       @default(true)
  payCard              Boolean       @default(true)
  payOnDelivery        Boolean       @default(false)
  showBranches         Boolean       @default(true)
  facebookUrl          String        @default("")
  instagramUrl         String        @default("")
  updatedAt            DateTime      @updatedAt
  qpaySettings         QPaySettings?
  macsSettings         MacsSettings?
}

model QPaySettings {
  id                    Int           @id @default(autoincrement())
  storeSettingsId       Int           @unique
  storeSettigns         StoreSettings @relation(fields: [storeSettingsId], references: [id], onDelete: Cascade)
  invoiceCode           String
  username              String
  password              String
  accessToken           String?
  refreshToken          String?
  tokenExpiresAt        DateTime?
  refreshTokenExpiresAt DateTime?
  testedAt              DateTime?
}

model MacsSettings {
  id              Int           @id @default(autoincrement())
  storeSettingsId Int           @unique
  storeSettings   StoreSettings @relation(fields: [storeSettingsId], references: [id], onDelete: Cascade)
  username        String        @default("")
  password        String        @default("")
  accessToken     String?
  refreshToken    String?
  testedAt        DateTime?
  updatedAt       DateTime      @updatedAt
}

model Invoice {
  id                 String    @id @default(cuid())
  invoiceId          String    @unique
  qrText             String?
  qpayShortUrl       String?
  paymentUrls        Json?
  createdAt          DateTime? @default(now())
  orderId            Int?
  cartId             Int?
  addressId          Int?
  branchId           Int?
  senderInvoiceNo    String
  amount             Int
  description        String?
  invoiceDescription String?
  expiryDate         DateTime?
  updatedAt          DateTime? @updatedAt
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  body      String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id        Int          @id @default(autoincrement())
  type      ReportType
  period    ReportPeriod
  startDate DateTime
  endDate   DateTime
  data      Json
  createdBy Int
  createdAt DateTime     @default(now())
  admin     User         @relation(fields: [createdBy], references: [id])
}

model ActivityLog {
  id          Int            @id @default(autoincrement())
  userId      Int
  action      ActivityAction
  description String?
  ip          String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PaymentType {
  ON_DELIVERY
  QPAY
  CARD
  BANK_APP
}

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  NEW
  INACTIVE
}

enum CategoryState {
  ACTIVE
  INACTIVE
}

enum ProductState {
  ACTIVE
  INACTIVE
}

enum OtpType {
  SIGNUP
  FORGOT_PASSWORD
  LOGIN
  CHANGE_EMAIL
}

enum NotificationType {
  ORDER
  PROMO
  INFO
  SYSTEM
}

enum ReportType {
  SALES
  ORDERS
  PRODUCTS
  CUSTOMERS
  REVENUE
}

enum ReportPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

enum ActivityAction {
  LOGIN
  LOGIN_GOOGLE
  SIGNUP
  LOGOUT
  PASSWORD_CHANGE
  PASSWORD_RESET
  PROFILE_UPDATE
  DEVICE_REGISTERED
}
