generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String?
  googleId      String?        @unique
  role          UserRole       @default(CUSTOMER)
  createdAt     DateTime       @default(now())
  deletedAt     DateTime?
  updatedAt     DateTime?      @updatedAt
  phone         String?
  status        UserStatus     @default(ACTIVE)
  addresses     Address[]
  cart          Cart?
  orders        Order[]
  reviews       Review[]
  wishlist      Wishlist[]
  sessions      Session[]
  fcms          FCM[]
  notifications Notification[]
  reports       Report[]
}

model Category {
  id        Int           @id @default(autoincrement())
  name      String
  createdAt DateTime      @default(now())
  deletedAt DateTime?
  parentId  Int?
  slug      String        @unique
  updatedAt DateTime?     @updatedAt
  state     CategoryState
  image     String?
  featured  Boolean       @default(false)
  parent    Category?     @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[]    @relation("SubCategories")
  products  Product[]
}

model Product {
  id            Int              @id @default(autoincrement())
  name          String
  description   String?
  price         Decimal          @db.Decimal(12, 2)
  stock         Int
  categoryId    Int
  createdAt     DateTime         @default(now())
  deletedAt     DateTime?
  discountPrice Decimal?         @db.Decimal(12, 2)
  isPublished   Boolean          @default(false)
  sku           String?          @unique
  slug          String           @unique
  updatedAt     DateTime?        @updatedAt
  featured      Boolean          @default(false)
  state         ProductState     @default(ACTIVE)
  cartItems     CartItem[]
  orderItems    OrderItem[]
  category      Category         @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  reviews       Review[]
  wishedBy      Wishlist[]
  features      ProductFeature[]
  colors        ProductColor[]
  productSizes  ProductSize[]
}

model ProductImage {
  id        Int       @id @default(autoincrement())
  url       String
  productId Int
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  updatedAt DateTime? @updatedAt
  product   Product   @relation(fields: [productId], references: [id])
}

model ProductFeature {
  id          Int     @id @default(autoincrement())
  productId   Int
  title       String
  description String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model ProductColor {
  id        Int     @id @default(autoincrement())
  productId Int
  hex       String
  name      String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model ProductSize {
  id        Int     @id @default(autoincrement())
  productId Int
  sizeName  String
  value     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Cart {
  id         Int        @id @default(autoincrement())
  userId     Int        @unique
  deletedAt  DateTime?
  updatedAt  DateTime?  @updatedAt
  totalCount Int        @default(0)
  totalPrice Decimal    @default(0) @db.Decimal(12, 2)
  user       User       @relation(fields: [userId], references: [id])
  items      CartItem[]
}

model CartItem {
  id        Int       @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int
  deletedAt DateTime?
  updatedAt DateTime? @updatedAt
  createdAt DateTime  @default(now())
  cart      Cart      @relation(fields: [cartId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
}

model Order {
  id          Int         @id @default(autoincrement())
  orderNumber String      @unique
  userId      Int
  status      OrderStatus @default(PENDING)
  totalPrice  Decimal     @default(0) @db.Decimal(12, 2)
  totalCount  Int         @default(0)
  createdAt   DateTime    @default(now())
  addressId   Int?
  deletedAt   DateTime?
  updatedAt   DateTime?   @updatedAt
  note        String?
  address     Address?    @relation(fields: [addressId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
  payment     Payment?
}

model OrderItem {
  id        Int       @id @default(autoincrement())
  orderId   Int
  productId Int
  price     Decimal   @db.Decimal(12, 2)
  quantity  Int
  deletedAt DateTime?
  updatedAt DateTime? @updatedAt
  order     Order     @relation(fields: [orderId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
}

model Payment {
  id        Int         @id @default(autoincrement())
  orderId   Int         @unique
  method    String
  amount    Decimal     @db.Decimal(12, 2)
  status    String      @default("PENDING")
  deletedAt DateTime?
  updatedAt DateTime?   @updatedAt
  type      PaymentType @default(QPAY)
  order     Order       @relation(fields: [orderId], references: [id])
}

model Review {
  id        Int       @id @default(autoincrement())
  rating    Int
  comment   String?
  userId    Int
  productId Int
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  updatedAt DateTime? @updatedAt
  product   Product   @relation(fields: [productId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model Address {
  id         Int       @id @default(autoincrement())
  city       String
  khoroo     String
  detail     String
  phone      String
  latitude   Decimal?
  longitude  Decimal?
  userId     Int
  isMain     Boolean   @default(false)
  deletedAt  DateTime?
  districtId Int
  user       User      @relation(fields: [userId], references: [id])
  orders     Order[]
  district   District  @relation(fields: [districtId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  lastActivity DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Otp {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  type      OtpType

  @@unique([email, type])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model FCM {
  id        Int       @id @default(autoincrement())
  token     String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
}

model District {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  createdAt   DateTime  @default(now())
  deliverable Boolean   @default(true)
  addresses   Address[]
}

model StoreSettings {
  id                   Int      @id @default(autoincrement())
  storeName            String   @default("IShop")
  storeDesc            String   @default("")
  phone                String   @default("")
  email                String   @default("")
  address              String   @default("")
  fee                  Decimal  @default(0) @db.Decimal(12, 2)
  feeThreshold         Decimal  @default(0) @db.Decimal(12, 2)
  onlyInStock          Boolean  @default(false)
  onlyPublished        Boolean  @default(true)
  showStatProducts     Boolean  @default(true)
  showStatOrders       Boolean  @default(true)
  showStatSatisfaction Boolean  @default(true)
  showStatDelivery     Boolean  @default(true)
  payQpay              Boolean  @default(true)
  payBankApp           Boolean  @default(true)
  payCard              Boolean  @default(true)
  payOnDelivery        Boolean  @default(false)
  updatedAt            DateTime @updatedAt
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  body      String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id        Int          @id @default(autoincrement())
  type      ReportType
  period    ReportPeriod
  startDate DateTime
  endDate   DateTime
  data      Json
  createdBy Int
  createdAt DateTime     @default(now())
  admin     User         @relation(fields: [createdBy], references: [id])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PaymentType {
  ON_DELIVERY
  QPAY
  CARD
  BANK_APP
}

enum UserRole {
  CUSTOMER
  ADMIN
  MANAGER
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  NEW
  INACTIVE
}

enum CategoryState {
  ACTIVE
  INACTIVE
}

enum ProductState {
  ACTIVE
  INACTIVE
}

enum OtpType {
  SIGNUP
  FORGOT_PASSWORD
  LOGIN
  CHANGE_EMAIL
}

enum NotificationType {
  ORDER
  PROMO
  INFO
  SYSTEM
}

enum ReportType {
  SALES
  ORDERS
  PRODUCTS
  CUSTOMERS
  REVENUE
}

enum ReportPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}
